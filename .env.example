# Optional real AI provider integration.
# If OPENAI_API_KEY is missing, NurOS uses the local rule-based AI Core fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Future hosted database adapter.
DATABASE_PROVIDER=json
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Local server port can also be passed as: node server.js 4174
PORT=4174
APP_URL=http://localhost:4174
NUROS_DEPLOY_MODE=development

# Security tuning.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=25
SESSION_TTL_DAYS=30
AUTH_TOKEN_TTL_MINUTES=30
AUTH_EXPOSE_DEV_TOKENS=true
EMAIL_PROVIDER=log
EMAIL_FROM=NurOS <noreply@nuros.local>
RESEND_API_KEY=
