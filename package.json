  "description": "NurOS personal AI operating system with local auth, API, AI Core, reminders, and storage adapters",
  "scripts": {
    "start": "node server.js",
    "start:4174": "node server.js 4174",
    "start:production": "set NUROS_DEPLOY_MODE=production&& node server.js",
