    "test": "node tests/config-report.js && node tests/env-validation.js && node tests/static-smoke.js && node tests/api-smoke.js",
    "test:api": "node tests/api-smoke.js",
    "test:static": "node tests/static-smoke.js",
    "test:config": "node tests/config-report.js",
    "test:env": "node tests/env-validation.js",
    "test:api:supabase": "set DATABASE_PROVIDER=supabase&& node tests/api-smoke.js",
    "migrate:supabase": "node scripts/migrate-json-to-supabase.js",
    "check:health": "node scripts/check-health.js",
    "validate:env": "node scripts/validate-env.js",
    "prepush:report": "node scripts/pre-push-report.js"
